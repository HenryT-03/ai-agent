# Qwen Local Model Configuration
# Copy this to .env and adjust as needed

# Ollama server URL (defaults to http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model ID (defaults to qwen2)
# Options: qwen2, qwen2:7b, qwen2:13b, etc.
MODEL_ID=qwen2

# Keep these from original setup if needed for other purposes
RAPID_API_KEY=your_rapid_api_key_here
SEO_ACCESS_TOKEN=your_seo_token_here
